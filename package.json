{
  "name": "flashbang",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "codegen": "bun scripts/codegen.ts",
    "build": "bun scripts/build.ts",
    "build:sw": "bun build src/sw/sw.ts --outdir dist --entry-naming sw.js --minify --target browser --format esm",
    "build:ui": "bun build src/ui/app.ts --outdir dist --entry-naming app.js --minify --target browser",
    "build:css": "bunx unocss 'src/ui/home.html' 'src/ui/bench.html' 'src/ui/app.ts' 'src/ui/bench.ts' 'src/ui/liquid-metal.ts' -o dist/styles.css --minify",
    "dev": "bun --hot scripts/dev.ts",
    "start": "bun scripts/start.ts",
    "check": "biome check",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "fix": "biome check --write",
    "profile": "bun scripts/profile.ts",
    "clean": "bun -e \"import{rmSync}from'fs';rmSync('dist',{recursive:true,force:true})\"",
    "test": "bun test",
    "test:e2e": "bun run build && bunx playwright test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@minify-html/node": "^0.18.1",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@unocss/cli": "^66.7.5",
    "typescript": "^7.0.2",
    "unocss": "^66.7.5"
  },
  "dependencies": {}
}
